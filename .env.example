# Copy this file to .env and fill in your actual values.
# The application loads this automatically via python-dotenv.
# ⚠️  NEVER commit your real .env file — it is already in .gitignore.

# ── Groq LLM (used by the /alerts/{id}/explain endpoint) ──────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_key_here

# Groq model to use for alert explanations.
# llama-3.3-70b-versatile is the recommended default (fast, free-tier available).
GROQ_MODEL=llama-3.3-70b-versatile

# ── FastAPI base URL (used by the Streamlit dashboard) ────────────────────────
# Leave as-is for local development; change for remote/Docker deployments.
NIDS_API_URL=http://localhost:8000

# ── API Authentication ─────────────────────────────────────────────────────────
# If set, mutating endpoints (/predict, /predict/batch, DELETE /alerts) require
# an X-API-Key header matching this value.
# Leave empty for local development (key check is bypassed when unset).
# Generate a strong key for production: python -c "import secrets; print(secrets.token_hex(32))"
NIDS_API_KEY=

# ── CORS (FastAPI allowed origins) ────────────────────────────────────────────
# Comma-separated list of origins allowed to make cross-origin requests to the API.
# Defaults to localhost:8501 (Streamlit) and localhost:3000 if unset.
# Set this to your deployed dashboard URL in production.
NIDS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501
